@page
@model LoginModel

@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="auth-shell">
    <section class="auth-left">
        <div>
            <img src="~/img/logo-baykus.png" alt="Baykus Sistema" class="auth-brand-logo" />
        </div>

        <div class="auth-copy">
            <div class="auth-kicker">Plataforma empresarial modular</div>

            <h1 class="auth-title">Gestioná tu empresa desde un solo lugar.</h1>

            <p class="auth-description">
                Baykus centraliza empleados, perfiles, documentación, planillas horarias y módulos internos
                en una plataforma simple, segura y adaptable a cada organización.
            </p>

            <div class="auth-features">
                <div class="auth-feature">Gestión de empleados</div>
                <div class="auth-feature">Planillas horarias</div>
                <div class="auth-feature">Roles y permisos</div>
                <div class="auth-feature">Instalación por empresa</div>
            </div>
        </div>

        <div class="small opacity-75">
            Baykus Sistema · v0.1
        </div>
    </section>

    <section class="auth-right">
        <div class="auth-card">
            <div class="auth-card-header">
                <h2 class="auth-card-title">Bienvenida</h2>
                <p class="auth-card-subtitle">Ingresá con tu cuenta para acceder al panel.</p>
            </div>

            <form id="account" method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="nombre@empresa.com" />
                    <span asp-validation-for="Input.Email"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">Contraseña</label>
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="Ingresá tu contraseña" />
                    <span asp-validation-for="Input.Password"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label" asp-for="Input.RememberMe">
                            Recordarme
                        </label>
                    </div>

                    <a asp-page="./ForgotPassword">Olvidé mi contraseña</a>
                </div>

                <button id="login-submit" type="submit" class="btn btn-primary auth-submit">
                    Iniciar sesión
                </button>

                <div class="auth-divider"></div>

                <div class="auth-links">
                    <span>
                        ¿Todavía no tenés usuario?
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Crear cuenta</a>
                    </span>
                </div>

                <p class="auth-small-note">
                    Acceso exclusivo para usuarios autorizados de la empresa.
                </p>
            </form>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}