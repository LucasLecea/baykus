@page
@model Baykus.Web.Pages.EmpleadoPages.CreateModel

@{
    ViewData["Title"] = "Nuevo empleado";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1 fw-bold">Nuevo empleado</h2>
        <p class="text-muted mb-0">
            Cargá los datos básicos del empleado para incorporarlo al sistema.
        </p>
    </div>

    <a asp-page="./Index" class="btn btn-light btn-volver">
        ← Volver
    </a>
</div>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4" role="alert"></div>

    <div class="baykus-card employee-form-card">

        <div class="form-section-header">
            <div>
                <h5 class="form-section-title">Datos personales</h5>
                <p class="form-section-subtitle">
                    Información principal para identificar al empleado.
                </p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="Empleado.Nombre" class="form-label baykus-label">
                    Nombre <span class="text-danger">*</span>
                </label>
                <input asp-for="Empleado.Nombre"
                       class="form-control baykus-input"
                       placeholder="Ej: Martina"
                       aria-required="true" />
                <span asp-validation-for="Empleado.Nombre" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Empleado.Apellido" class="form-label baykus-label">
                    Apellido <span class="text-danger">*</span>
                </label>
                <input asp-for="Empleado.Apellido"
                       class="form-control baykus-input"
                       placeholder="Ej: Bazán"
                       aria-required="true" />
                <span asp-validation-for="Empleado.Apellido" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Empleado.Dni" class="form-label baykus-label">
                    DNI
                </label>
                <input asp-for="Empleado.Dni"
                       class="form-control baykus-input"
                       placeholder="Ej: 40123456" />
                <span asp-validation-for="Empleado.Dni" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Empleado.Email" class="form-label baykus-label">
                    Email
                </label>
                <input asp-for="Empleado.Email"
                       class="form-control baykus-input"
                       placeholder="nombre@empresa.com" />
                <span asp-validation-for="Empleado.Email" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Empleado.Telefono" class="form-label baykus-label">
                    Teléfono
                </label>
                <input asp-for="Empleado.Telefono"
                       class="form-control baykus-input"
                       placeholder="Ej: 261 555 1234" />
                <span asp-validation-for="Empleado.Telefono" class="text-danger small"></span>
            </div>
        </div>

        <div class="baykus-form-divider"></div>

        <div class="form-section-header mt-3">
            <div>
                <h5 class="form-section-title">Datos laborales</h5>
                <p class="form-section-subtitle">
                    Información relacionada al puesto, sector y estado dentro de la empresa.
                </p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <label asp-for="Empleado.SectorId" class="form-label baykus-label">
                    Sector <span class="text-danger">*</span>
                </label>

                <select asp-for="Empleado.SectorId"
                        asp-items="Model.SectoresSelectList"
                        class="form-select baykus-input"
                        id="sectorSelect">
                    <option value="">Seleccionar sector</option>
                </select>

                <span asp-validation-for="Empleado.SectorId" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Empleado.PuestoId" class="form-label baykus-label">
                    Puesto <span class="text-danger">*</span>
                </label>

                <select asp-for="Empleado.PuestoId"
                        asp-items="Model.PuestosSelectList"
                        class="form-select baykus-input"
                        id="puestoSelect"
                        disabled>
                    <option value="">Primero seleccioná un sector</option>
                </select>

                <span asp-validation-for="Empleado.PuestoId" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Empleado.FechaIngreso" class="form-label baykus-label">
                    Fecha de ingreso
                </label>
                <input asp-for="Empleado.FechaIngreso"
                       type="date"
                       class="form-control baykus-input" />
                <span asp-validation-for="Empleado.FechaIngreso" class="text-danger small"></span>
            </div>

            <div class="col-md-12">
                <div class="baykus-switch-card">
                    <div>
                        <label asp-for="Empleado.Activo" class="form-label baykus-label mb-1">
                            Estado del empleado
                        </label>
                        <p class="text-muted mb-0 small">
                            Si está activo, aparecerá como empleado vigente dentro del sistema.
                        </p>
                    </div>

                    <div class="form-check form-switch baykus-switch">
                        <input asp-for="Empleado.Activo"
                               class="form-check-input"
                               type="checkbox"
                               role="switch" />
                        <label class="form-check-label" asp-for="Empleado.Activo">
                            Activo
                        </label>
                    </div>
                </div>

                <span asp-validation-for="Empleado.Activo" class="text-danger small"></span>
            </div>
        </div>

        <div class="baykus-form-divider"></div>

        <div class="form-section-header mt-5">
            <div>
                <h5 class="form-section-title">Acceso al sistema</h5>
                <p class="form-section-subtitle">
                    Opcionalmente, podés crear el usuario de acceso a Baykus al mismo tiempo que cargás el empleado.
                </p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="PerfilSeleccionadoId" class="form-label baykus-label">
                    Perfil de acceso
                </label>

                <select asp-for="PerfilSeleccionadoId"
                        asp-items="Model.PerfilesSelectList"
                        class="form-select baykus-input">
                    <option value="">Sin perfil asignado</option>
                </select>

                <span asp-validation-for="PerfilSeleccionadoId" class="text-danger small"></span>

                <p class="text-muted small mt-2 mb-0">
                    Si creás un usuario de acceso, el perfil será obligatorio.
                </p>
            </div>

            <div class="col-md-6">
                <div class="baykus-switch-card h-100">
                    <div>
                        <label class="form-label baykus-label mb-1">
                            Usuario de acceso
                        </label>

                        <p class="text-muted mb-0 small">
                            Si activás esta opción, se creará un usuario con el email del empleado.
                        </p>
                    </div>

                    <div class="form-check form-switch baykus-switch">
                        <input asp-for="CrearUsuarioAcceso"
                               class="form-check-input"
                               type="checkbox"
                               role="switch" />

                        <label class="form-check-label" asp-for="CrearUsuarioAcceso">
                            Crear usuario
                        </label>
                    </div>
                </div>

                <span asp-validation-for="CrearUsuarioAcceso" class="text-danger small"></span>
            </div>
        </div>

        <div class="baykus-form-actions mt-3">
            <a asp-page="./Index" class="btn btn-outline-secondary btn-baykus-secondary">
                Cancelar
            </a>

            <button type="submit" class="btn btn-primary btn-baykus-primary">
                Guardar empleado
            </button>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const puestos = @Html.Raw(Model.PuestosJson);

        const sectorSelect = document.getElementById("sectorSelect");
        const puestoSelect = document.getElementById("puestoSelect");

        const puestoSeleccionado = "@Model.Empleado.PuestoId";

        function cargarPuestosPorSector() {
            const sectorId = sectorSelect.value;

            puestoSelect.innerHTML = "";

            if (!sectorId) {
                puestoSelect.disabled = true;

                const option = document.createElement("option");
                option.value = "";
                option.textContent = "Primero seleccioná un sector";
                puestoSelect.appendChild(option);

                return;
            }

            const puestosFiltrados = puestos.filter(p => p.sectorId == sectorId);

            puestoSelect.disabled = false;

            const optionDefault = document.createElement("option");
            optionDefault.value = "";
            optionDefault.textContent = puestosFiltrados.length > 0
                ? "Seleccionar puesto"
                : "No hay puestos cargados para este sector";

            puestoSelect.appendChild(optionDefault);

            puestosFiltrados.forEach(puesto => {
                const option = document.createElement("option");
                option.value = puesto.id;
                option.textContent = puesto.nombre;

                if (puestoSeleccionado && puestoSeleccionado == puesto.id) {
                    option.selected = true;
                }

                puestoSelect.appendChild(option);
            });

            if (puestosFiltrados.length === 0) {
                puestoSelect.disabled = true;
            }
        }

        sectorSelect.addEventListener("change", function () {
            puestoSelect.value = "";
            cargarPuestosPorSector();
        });

        cargarPuestosPorSector();
    </script>
}