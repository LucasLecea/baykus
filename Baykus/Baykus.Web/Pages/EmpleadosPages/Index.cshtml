@page
@model Baykus.Web.Pages.Empleados.IndexModel

@{
    ViewData["Title"] = "Empleados";
}

<div class="page-header mb-4">
    <div>
        <h1 class="page-title">Empleados</h1>
        <p class="page-subtitle">
            Gestioná los perfiles de las personas registradas en la empresa.
        </p>
    </div>

    <a asp-page="Create" class="btn btn-primary btn-nuevo">
        <span class="me-1">＋</span>
        Nuevo empleado
    </a>
</div>

<div class="card baykus-card">
    <div class="card-body">

        @if (Model.Empleados != null && Model.Empleados.Any())
        {
            <div class="table-responsive">
                <table class="table baykus-table align-middle w-100">
                    <thead>
                        <tr>
                            <th>Empleado</th>
                            <th>Email</th>
                            <th>Puesto</th>
                            <th>Sector</th>
                            <th>Estado</th>
                            <th class="text-end acciones-header">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.Empleados)
                        {
                            <tr>
                                <td class="empleado-cell">
                                    <div class="puesto-nombre">
                                        @item.Apellido, @item.Nombre
                                    </div>

                                    <div class="empleado-meta">
                                        <span>
                                            DNI:
                                            @if (!string.IsNullOrWhiteSpace(item.Dni))
                                            {
                                                @item.Dni
                                            }
                                            else
                                            {
                                                <span>Sin DNI</span>
                                            }
                                        </span>
                                        <span>
                                            Ingreso: @(item.FechaIngreso?.ToString("dd/MM/yyyy") ?? "Sin fecha")
                                        </span>
                                    </div>
                                </td>

                                <td class="descripcion-cell">
                                    @if (!string.IsNullOrWhiteSpace(item.Email))
                                    {
                                        <span title="@item.Email">
                                            @item.Email
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin email</span>
                                    }
                                </td>

                                <td>
                                    @if (item.Puesto != null)
                                    {
                                        <span>
                                            @item.Puesto.Nombre
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin puesto</span>
                                    }
                                </td>

                                <td>
                                    @if (item.Sector != null)
                                    {
                                        <span>
                                            @item.Sector.Nombre
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin sector</span>
                                    }
                                </td>

                                <td>
                                    @if (item.Activo)
                                    {
                                        <span class="badge badge-activo">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-inactivo">Inactivo</span>
                                    }
                                </td>

                                <td class="text-end acciones-cell">
                                    <div class="acciones-tabla">
                                        <a asp-page="./Details"
                                           asp-route-id="@item.Id"
                                           class="btn-icon-action action-view"
                                           title="Ver detalle"
                                           aria-label="Ver detalle">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>

                                        <a asp-page="./Edit"
                                           asp-route-id="@item.Id"
                                           class="btn-icon-action action-edit"
                                           title="Editar empleado"
                                           aria-label="Editar empleado">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>

                                        <a asp-page="./Delete"
                                           asp-route-id="@item.Id"
                                           class="btn-icon-action action-delete"
                                           title="Eliminar empleado"
                                           aria-label="Eliminar empleado">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">👥</div>

                <h3>Todavía no hay empleados cargados</h3>

                <p>
                    Creá el primer empleado para empezar a usar el módulo de recursos humanos.
                </p>

                <a asp-page="Create" class="btn btn-primary">
                    Crear primer empleado
                </a>
            </div>
        }

    </div>
</div>
<style>
    .col-empleado {
        width: 22%;
    }

    .col-email {
        width: 18%;
    }

    .col-puesto {
        width: 22%;
    }

    .col-sector {
        width: 18%;
    }

    .col-estado {
        width: 10%;
    }
</style>