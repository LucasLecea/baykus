@page
@model Baykus.Web.Pages.MiPlanillaHoraria.IndexModel
@using Baykus.Web.Models.Enums

@{
    ViewData["Title"] = "Mi planilla horaria";
}

<div class="baykus-page-header">
    <div>
        <h1>Mi planilla horaria</h1>
        <p>Cargá y consultá tus planillas horarias mensuales.</p>
    </div>

    <div class="baykus-page-actions">
        <a asp-page="./Create" class="btn btn-primary">
            Nueva planilla
        </a>
    </div>
</div>

@if (Model.Empleado == null)
{
    <div class="baykus-card">
        <div class="baykus-empty-state">
            <h3>No encontramos un empleado vinculado a tu usuario</h3>
            <p>
                Para cargar tu planilla, tu usuario debe estar vinculado a un empleado activo.
            </p>
        </div>
    </div>
}
else
{
    <div class="baykus-card mb-4">
        <div class="row">
            <div class="col-md-4">
                <small class="text-muted">Empleado</small>
                <div><strong>@Model.Empleado.Apellido, @Model.Empleado.Nombre</strong></div>
            </div>
            <div class="col-md-4">
                <small class="text-muted">Sector</small>
                <div>@(Model.Empleado.Sector?.Nombre ?? "-")</div>
            </div>
            <div class="col-md-4">
                <small class="text-muted">Puesto</small>
                <div>@(Model.Empleado.Puesto?.Nombre ?? "-")</div>
            </div>
        </div>
    </div>

    <div class="baykus-card">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h2 class="form-section-title mb-1">Mis planillas</h2>
                <p class="form-section-subtitle mb-0">
                    Historial de planillas cargadas.
                </p>
            </div>
        </div>

        @if (Model.Planillas.Any())
        {
            <div class="table-responsive">
                <table class="table baykus-table align-middle">
                    <thead>
                        <tr>
                            <th>Período</th>
                            <th>Estado</th>
                            <th>Total horas</th>
                            <th>Horas extra</th>
                            <th>Presentación</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var planilla in Model.Planillas)
                        {
                            <tr>
                                <td>@planilla.Mes/@planilla.Anio</td>
                                <td>
                                    <span class="baykus-status-badge @GetEstadoClass(planilla.Estado)">
                                        @planilla.Estado
                                    </span>
                                </td>
                                <td>@planilla.TotalHorasTrabajadas</td>
                                <td>@(planilla.TotalHorasExtra50 + planilla.TotalHorasExtra100)</td>
                                <td>
                                    @(planilla.FechaPresentacion?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                                </td>
                                <td class="text-end">
                                    <a asp-page="./Details"
                                       asp-route-id="@planilla.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        Ver
                                    </a>

                                    @if (planilla.Estado == EstadoPlanillaHoraria.Borrador || planilla.Estado == EstadoPlanillaHoraria.Rechazada)
                                    {
                                        <a asp-page="./Edit"
                                           asp-route-id="@planilla.Id"
                                           class="btn btn-sm btn-outline-secondary">
                                            Editar
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="baykus-empty-state">
                <h3>Todavía no cargaste planillas</h3>
                <p>Creá tu primera planilla horaria para comenzar a registrar tus horas.</p>
                <a asp-page="./Create" class="btn btn-primary">
                    Crear planilla
                </a>
            </div>
        }
    </div>
}

@functions {
    private string GetEstadoClass(EstadoPlanillaHoraria estado)
    {
        return estado switch
        {
            EstadoPlanillaHoraria.Borrador => "status-muted",
            EstadoPlanillaHoraria.Presentada => "status-warning",
            EstadoPlanillaHoraria.Aprobada => "status-success",
            EstadoPlanillaHoraria.Rechazada => "status-danger",
            EstadoPlanillaHoraria.Cerrada => "status-info",
            _ => "status-muted"
        };
    }
}