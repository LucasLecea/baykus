@page
@model Baykus.Web.Pages.Empleados.IndexModel

@{
    ViewData["Title"] = "Empleados";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Empleados</h2>
        <p class="text-muted mb-0">Gestioná los perfiles de las personas registradas en la empresa.</p>
    </div>

    <a asp-page="Create" class="btn btn-primary">
        + Nuevo empleado
    </a>
</div>

<div class="baykus-card">
    @if (Model.Empleados != null && Model.Empleados.Any())
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Empleado</th>
                        <th>DNI</th>
                        <th>Email</th>
                        <th>Puesto</th>
                        <th>Sector</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Empleados)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold">@item.Apellido, @item.Nombre</div>
                                <div class="text-muted small">
                                    Ingreso: @(item.FechaIngreso?.ToString("dd/MM/yyyy") ?? "Sin fecha")
                                </div>
                            </td>
                            <td>@item.Dni</td>
                            <td>@item.Email</td>
                            <td>@item.Puesto</td>
                            <td>@item.Sector</td>
                            <td>
                                @if (item.Activo)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">
                                        Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">
                                        Inactivo
                                    </span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                                    Ver
                                </a>
                                <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                    Editar
                                </a>
                                <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                    Eliminar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h5 class="fw-bold">Todavía no hay empleados cargados</h5>
            <p class="text-muted">Creá el primer empleado para empezar a usar el módulo de recursos humanos.</p>

            <a asp-page="Create" class="btn btn-primary">
                Crear primer empleado
            </a>
        </div>
    }
</div>