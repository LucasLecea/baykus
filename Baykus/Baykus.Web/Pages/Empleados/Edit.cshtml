@page
@model Baykus.Web.Pages.EmpleadoPages.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Empleado</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Empleado.Id" />
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Empleado.Nombre" class="control-label"></label>
                <input asp-for="Empleado.Nombre" class="form-control" aria-required="true"/>
                <span asp-validation-for="Empleado.Nombre" class="text-danger"></span>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Empleado.Apellido" class="control-label"></label>
                <input asp-for="Empleado.Apellido" class="form-control" aria-required="true"/>
                <span asp-validation-for="Empleado.Apellido" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Empleado.Dni" class="control-label"></label>
                <input asp-for="Empleado.Dni" class="form-control" />
                <span asp-validation-for="Empleado.Dni" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Empleado.Email" class="control-label"></label>
                <input asp-for="Empleado.Email" class="form-control" />
                <span asp-validation-for="Empleado.Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Empleado.Telefono" class="control-label"></label>
                <input asp-for="Empleado.Telefono" class="form-control" />
                <span asp-validation-for="Empleado.Telefono" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Empleado.Puesto" class="control-label"></label>
                <input asp-for="Empleado.Puesto" class="form-control" />
                <span asp-validation-for="Empleado.Puesto" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Empleado.Sector" class="control-label"></label>
                <input asp-for="Empleado.Sector" class="form-control" />
                <span asp-validation-for="Empleado.Sector" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Empleado.FechaIngreso" class="control-label"></label>
                <input asp-for="Empleado.FechaIngreso" class="form-control" />
                <span asp-validation-for="Empleado.FechaIngreso" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Empleado.Activo" class="control-label"></label>
                <input asp-for="Empleado.Activo" class="form-check-input" />
                <span asp-validation-for="Empleado.Activo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Empleado.FechaAlta" class="control-label"></label>
                <input asp-for="Empleado.FechaAlta" class="form-control" />
                <span asp-validation-for="Empleado.FechaAlta" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
