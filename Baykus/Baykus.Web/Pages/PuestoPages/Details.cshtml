@page
@model Baykus.Web.Pages.PuestoPages.DetailsModel

@{
    ViewData["Title"] = "Detalle del puesto";
}

<div class="page-header mb-4">
    <div>
        <h1 class="page-title">Detalle del puesto</h1>
        <p class="page-subtitle">
            Consultá la información registrada para este puesto de trabajo.
        </p>
    </div>

    <a asp-page="./Index" class="btn btn-light btn-volver">
        ← Volver
    </a>
</div>

<div class="baykus-card employee-detail-card">
    <div class="employee-profile-header mb-4">
        <div class="employee-profile-main">
            <div class="employee-avatar" style="font-size: 2.4rem !important">
                💼
            </div>

            <div>
                <div class="employee-profile-name">
                    @Model.Puesto.Nombre
                </div>

                <div class="employee-profile-subtitle">
                    Puesto de trabajo
                </div>
            </div>
        </div>

        <div class="employee-profile-actions">
            <a asp-page="./Edit"
               asp-route-id="@Model.Puesto.Id"
               class="btn btn-primary btn-form">
                Editar puesto
            </a>
        </div>
    </div>

    <div class="detail-section">
        <div class="detail-list">

            <div class="detail-item">
                <div class="detail-label">
                    Nombre
                </div>
                <div class="detail-value">
                    @Model.Puesto.Nombre
                </div>
            </div>

            <div class="detail-item">
                <div class="detail-label">
                    Descripción
                </div>
                <div class="detail-value">
                    @if (!string.IsNullOrWhiteSpace(Model.Puesto.Descripcion))
                    {
                        @Model.Puesto.Descripcion
                    }
                    else
                    {
                        <span class="text-muted">Sin descripción</span>
                    }
                </div>
            </div>

            <div class="detail-item">
                <div class="detail-label">
                    Estado
                </div>
                <div class="detail-value">
                    @if (Model.Puesto.Activo)
                    {
                        <span class="baykus-badge-success">Activo</span>
                    }
                    else
                    {
                        <span class="baykus-badge-muted">Inactivo</span>
                    }
                </div>
            </div>

            <div class="detail-item">
                <div class="detail-label">
                    Fecha de creación
                </div>
                <div class="detail-value">
                    @Model.Puesto.FechaCreacion.ToString("dd/MM/yyyy")
                </div>
            </div>

        </div>
    </div>
</div>