@using Microsoft.AspNetCore.Identity
@using Baykus.Web.Data
@using Baykus.Web.Services.Menu
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject IMenuUsuarioService MenuUsuarioService

@{
    var currentPath = Context.Request.Path.Value?.ToLower() ?? "";

    bool IsActive(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return false;
        }

        string NormalizePath(string value)
        {
            value = value.Trim().ToLower();

            if (!value.StartsWith("/"))
            {
                value = "/" + value;
            }

            if (value.EndsWith("/index"))
            {
                value = value[..^6];

                if (string.IsNullOrWhiteSpace(value))
                {
                    value = "/";
                }
            }

            return value;
        }

        var pathMenu = NormalizePath(path);
        var pathActual = NormalizePath(currentPath);

        if (pathMenu == "/")
        {
            return pathActual == "/";
        }

        return pathActual == pathMenu || pathActual.StartsWith(pathMenu + "/");
    };

    string ObtenerUrlMenu(MenuUsuarioDto menu)
    {
        if (!string.IsNullOrWhiteSpace(menu.Page))
        {
            var page = menu.Page;

            if (!page.EndsWith("/Index", StringComparison.OrdinalIgnoreCase) &&
                page != "/Index")
            {
                page = page + "/Index";
            }

            return Url.Page(page, new { area = menu.Area }) ?? "#";
        }

        if (!string.IsNullOrWhiteSpace(menu.Url))
        {
            return menu.Url;
        }

        return "#";
    }

    string ObtenerCollapseId(MenuUsuarioDto menu)
    {
        return $"menu_{menu.Codigo.Replace(" ", "_").Replace("-", "_")}";
    }

    var menuUsuario = new List<MenuUsuarioDto>();

    if (SignInManager.IsSignedIn(User))
    {
        var applicationUserId = UserManager.GetUserId(User);

        if (!string.IsNullOrWhiteSpace(applicationUserId))
        {
            menuUsuario = await MenuUsuarioService.ObtenerMenuUsuarioAsync(applicationUserId);
        }
    }

    bool EsBootstrapIcon(string? icono)
    {
        return !string.IsNullOrWhiteSpace(icono)
               && icono.Trim().StartsWith("bi ", StringComparison.OrdinalIgnoreCase);
    }
}

<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Baykus</title>

    <script>
            (function () {
                try {
                    var savedTheme = localStorage.getItem("baykus-theme");
                    var theme = savedTheme === "dark" || savedTheme === "light"
                        ? savedTheme
                        : "light";

                    document.documentElement.setAttribute("data-theme", theme);
                } catch {
                    document.documentElement.setAttribute("data-theme", "light");
                }
            })();
    </script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/baykus.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
</head>

<body>
    @if (SignInManager.IsSignedIn(User))
    {
        <div class="baykus-app">

            <aside class="baykus-sidebar">
                <div class="sidebar-brand">
                    <img src="~/img/logo-baykus.png"
                         alt="Baykus Sistema"
                         class="sidebar-logo sidebar-logo-full" />

                    <button type="button"
                            id="sidebarToggle"
                            class="sidebar-collapse-toggle"
                            aria-label="Minimizar menú"
                            title="Minimizar menú">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                </div>

                <nav class="sidebar-menu">
                    @if (!menuUsuario.Any())
                    {
                        <div class="px-3 py-2 text-muted small">
                            No tenés menús asignados.
                        </div>
                    }
                    else
                    {
                        foreach (var menu in menuUsuario)
                        {
                            var tieneHijos = menu.Hijos.Any();
                            var menuActivo = IsActive(menu.Page) || menu.Hijos.Any(h => IsActive(h.Page));
                            var collapseId = ObtenerCollapseId(menu);

                            if (tieneHijos)
                            {
                                <div class="sidebar-group">
                                    <button class="sidebar-link sidebar-group-toggle @(menuActivo ? "active" : "")"
                                            type="button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#@collapseId"
                                            aria-expanded="@(menuActivo.ToString().ToLower())"
                                            aria-controls="@collapseId">
                                        <span class="sidebar-icon">
                                            @if (EsBootstrapIcon(menu.Icono))
                                            {
                                                <i class="@menu.Icono"></i>
                                            }
                                            else
                                            {
                                                <span>@(menu.Icono ?? "•")</span>
                                            }
                                        </span>

                                        <span class="sidebar-label">@menu.Nombre</span>

                                        <span class="sidebar-chevron">
                                            <i class="bi bi-chevron-down"></i>
                                        </span>
                                    </button>

                                    <div class="collapse sidebar-submenu @(menuActivo ? "show" : "")" id="@collapseId">
                                        @foreach (var hijo in menu.Hijos)
                                        {
                                            <a class="sidebar-sublink @(IsActive(hijo.Page) ? "active" : "")"
                                               href="@ObtenerUrlMenu(hijo)">
                                                <span class="sidebar-icon sidebar-subicon">
                                                    @if (EsBootstrapIcon(hijo.Icono))
                                                    {
                                                        <i class="@hijo.Icono"></i>
                                                    }
                                                    else
                                                    {
                                                        <span class="sidebar-dot"></span>
                                                    }
                                                </span>

                                                <span class="sidebar-label">@hijo.Nombre</span>
                                            </a>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <a class="sidebar-link @(IsActive(menu.Page) ? "active" : "")"
                                   href="@ObtenerUrlMenu(menu)">
                                    <span class="sidebar-icon">
                                        @if (EsBootstrapIcon(menu.Icono))
                                        {
                                            <i class="@menu.Icono"></i>
                                        }
                                        else
                                        {
                                            <span>@(menu.Icono ?? "•")</span>
                                        }
                                    </span>

                                    <span class="sidebar-label">@menu.Nombre</span>
                                </a>
                            }
                        }
                    }
                </nav>

                <div class="sidebar-footer">
                    <div class="small text-muted">Baykus v0.1</div>
                </div>
            </aside>

            <main class="baykus-main">
                <header class="baykus-topbar">
                    <div>
                        <h1 class="page-title">@ViewData["Title"]</h1>
                        <p class="page-subtitle">Panel de administración</p>
                    </div>

                    <div class="topbar-user">
                        <div class="user-info">
                            <div class="user-name">@User.Identity?.Name</div>
                            <div class="user-role">Usuario activo</div>
                        </div>

                        <button type="button"
                                id="themeToggle"
                                class="btn btn-baykus-theme"
                                aria-label="Cambiar tema"
                                title="Cambiar tema">
                            <span class="theme-toggle-icon" aria-hidden="true">🌙</span>
                            <span class="theme-toggle-text">Oscuro</span>
                        </button>

                        <form class="logout-form"
                              asp-area="Identity"
                              asp-page="/Account/Logout"
                              asp-route-returnUrl="/Identity/Account/Login"
                              method="post">
                            <button type="submit" class="btn btn-baykus-logout">
                                <span>Salir</span>
                            </button>
                        </form>
                    </div>
                </header>

                <section class="baykus-content">
                    @RenderBody()
                </section>
            </main>
        </div>
    }
    else
    {
        <main>
            @RenderBody()
        </main>
    }

    <style>
            
    </style>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
            const app = document.querySelector(".baykus-app");
            const toggle = document.getElementById("sidebarToggle");

            if (!app || !toggle) {
            return;
            }

            const icon = toggle.querySelector("i");

            function setCollapsed(isCollapsed) {
            app.classList.toggle("sidebar-collapsed", isCollapsed);
            localStorage.setItem("baykus-sidebar-collapsed", isCollapsed ? "true" : "false");

            toggle.setAttribute("title", isCollapsed ? "Expandir menú" : "Minimizar menú");
            toggle.setAttribute("aria-label", isCollapsed ? "Expandir menú" : "Minimizar menú");

            if (icon) {
            icon.className = isCollapsed ? "bi bi-chevron-right" : "bi bi-chevron-left";
            }
            }

            const savedState = localStorage.getItem("baykus-sidebar-collapsed") === "true";
            setCollapsed(savedState);

            toggle.addEventListener("click", function (event) {
            event.preventDefault();
            event.stopPropagation();

            const isCollapsed = app.classList.contains("sidebar-collapsed");
            setCollapsed(!isCollapsed);
            });
            });
        </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>