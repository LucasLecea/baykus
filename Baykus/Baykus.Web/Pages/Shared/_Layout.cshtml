@using Microsoft.AspNetCore.Identity
@using Baykus.Web.Data
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var currentPath = Context.Request.Path.Value?.ToLower() ?? "";

    bool IsActive(string path)
    {
        return currentPath.StartsWith(path.ToLower());
    }

    var abmsActivo =
        IsActive("/EmpleadosPages") ||
        IsActive("/PuestoPages") ||
        IsActive("/SectorPages");

    var gestionActivo =
        IsActive("/OkrPages") ||
        IsActive("/PlanillasHorarias") ||
        IsActive("/MiPlanillaHoraria");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Baykus</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/baykus.css" asp-append-version="true" />
</head>

<body>
    @if (SignInManager.IsSignedIn(User))
    {
        <div class="baykus-app">

            <aside class="baykus-sidebar">
                <div class="sidebar-brand">
                    <img src="~/img/logo-baykus.png" alt="Baykus Sistema" class="sidebar-logo" />
                </div>

                <nav class="sidebar-menu">
                    <a class="sidebar-link @(currentPath == "/" ? "active" : "")" asp-page="/Index">
                        <span class="sidebar-icon">⌂</span>
                        <span>Dashboard</span>
                    </a>

                    <div class="sidebar-group">
                        <button class="sidebar-link sidebar-group-toggle @(abmsActivo ? "active" : "")"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#menuAbms"
                                aria-expanded="@(abmsActivo.ToString().ToLower())"
                                aria-controls="menuAbms">
                            <span class="sidebar-icon">🗂️</span>
                            <span>ABMs</span>
                            <span class="sidebar-chevron">⌄</span>
                        </button>

                        <div class="collapse sidebar-submenu @(abmsActivo ? "show" : "")" id="menuAbms">
                            <a class="sidebar-sublink @(IsActive("/EmpleadosPages") ? "active" : "")"
                               asp-page="/EmpleadosPages/Index">
                                <span class="sidebar-dot"></span>
                                <span>Empleados</span>
                            </a>

                            <a class="sidebar-sublink @(IsActive("/SectorPages") ? "active" : "")"
                               asp-page="/SectorPages/Index">
                                <span class="sidebar-dot"></span>
                                <span>Sectores</span>
                            </a>

                            <a class="sidebar-sublink @(IsActive("/PuestoPages") ? "active" : "")"
                               asp-page="/PuestoPages/Index">
                                <span class="sidebar-dot"></span>
                                <span>Puestos</span>
                            </a>
                        </div>
                    </div>

                    <div class="sidebar-group">
                        <button class="sidebar-link sidebar-group-toggle @(gestionActivo ? "active" : "")"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#menuGestion"
                                aria-expanded="@(gestionActivo.ToString().ToLower())"
                                aria-controls="menuGestion">
                            <span class="sidebar-icon">📊</span>
                            <span>Gestión</span>
                            <span class="sidebar-chevron">⌄</span>
                        </button>

                        <div class="collapse sidebar-submenu @(gestionActivo ? "show" : "")" id="menuGestion">
                            <a class="sidebar-sublink @(IsActive("/OkrPages/Dashboard") ? "active" : "")"
                               asp-page="/OkrPages/Dashboard">
                                <span class="sidebar-dot"></span>
                                <span>Dashboard OKR</span>
                            </a>

                            <a class="sidebar-sublink @(IsActive("/OkrPages/Index")
                                                           || IsActive("/OkrPages")
                                                           || IsActive("/OkrPages/Create")
                                                           || IsActive("/OkrPages/Edit")
                                                           || IsActive("/OkrPages/Details")
                                                           || IsActive("/OkrPages/Delete") ? "active" : "")"
                               asp-page="/OkrPages/Index">
                                <span class="sidebar-dot"></span>
                                <span>Objetivos / OKR</span>
                            </a>

                            <a class="sidebar-sublink @(IsActive("/PlanillasHorarias") ? "active" : "")"
                               asp-page="/PlanillasHorarias/Index">
                                <span class="sidebar-dot"></span>
                                <span>Planillas horarias</span>
                            </a>

                            <a class="sidebar-sublink @(IsActive("/MiPlanillaHoraria") ? "active" : "")"
                               asp-page="/MiPlanillaHoraria/Index">
                                <span class="sidebar-dot"></span>
                                <span>Mi planilla</span>
                            </a>
                        </div>
                    </div>

                    <a class="sidebar-link" href="#">
                        <span class="sidebar-icon">📁</span>
                        <span>Documentación</span>
                    </a>

                    <a class="sidebar-link" href="#">
                        <span class="sidebar-icon">⚙</span>
                        <span>Configuración</span>
                    </a>
                </nav>

                <div class="sidebar-footer">
                    <div class="small text-muted">Baykus v0.1</div>
                </div>
            </aside>

            <main class="baykus-main">
                <header class="baykus-topbar">
                    <div>
                        <h1 class="page-title">@ViewData["Title"]</h1>
                        <p class="page-subtitle">Panel de administración</p>
                    </div>

                    <div class="topbar-user">
                        <div class="user-info">
                            <div class="user-name">@User.Identity?.Name</div>
                            <div class="user-role">Usuario activo</div>
                        </div>

                        <form class="logout-form" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
                            <button type="submit" class="btn btn-baykus-logout">
                                <span>Salir</span>
                            </button>
                        </form>
                    </div>
                </header>

                <section class="baykus-content">
                    @RenderBody()
                </section>
            </main>
        </div>
    }
    else
    {
        <main>
            @RenderBody()
        </main>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>