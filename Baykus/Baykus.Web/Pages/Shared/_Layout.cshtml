@using Microsoft.AspNetCore.Identity
@using Baykus.Web.Data
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Baykus</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/baykus.css" asp-append-version="true" />
</head>

<body>
    @if (SignInManager.IsSignedIn(User))
    {
        <div class="baykus-app">

            <aside class="baykus-sidebar">
                <div class="sidebar-brand">
                    <img src="~/img/logo-baykus.png" alt="Baykus Sistema" class="sidebar-logo" />
                </div>

                <nav class="sidebar-menu">
                    <a class="sidebar-link" asp-page="/Index">
                        <span class="sidebar-icon">⌂</span>
                        <span>Dashboard</span>
                    </a>

                    <a class="sidebar-link" asp-page="/Empleados/Index">
                        <span class="sidebar-icon">👥</span>
                        <span>Empleados</span>
                    </a>

                    <a class="sidebar-link" href="#">
                        <span class="sidebar-icon">🕒</span>
                        <span>Planillas horarias</span>
                    </a>

                    <a class="sidebar-link" href="#">
                        <span class="sidebar-icon">📁</span>
                        <span>Documentación</span>
                    </a>

                    <a class="sidebar-link" href="#">
                        <span class="sidebar-icon">⚙</span>
                        <span>Configuración</span>
                    </a>
                </nav>

                <div class="sidebar-footer">
                    <div class="small text-muted">Baykus v0.1</div>
                </div>
            </aside>

            <main class="baykus-main">
                <header class="baykus-topbar">
                    <div>
                        <h1 class="page-title">@ViewData["Title"]</h1>
                        <p class="page-subtitle">Panel de administración</p>
                    </div>

                    <div class="topbar-user">
                        <div class="user-info">
                            <div class="user-name">@User.Identity?.Name</div>
                            <div class="user-role">Usuario activo</div>
                        </div>

                        <form class="logout-form" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
                            <button type="submit" class="btn btn-baykus-logout">
                                <span>Salir</span>
                            </button>
                        </form>
                    </div>
                </header>

                <section class="baykus-content">
                    @RenderBody()
                </section>
            </main>
        </div>
    }
    else
    {
        <main>
            @RenderBody()
        </main>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>