@page "{id:int}"
@model Baykus.Web.Pages.OkrPages.DetailsModel
@using Baykus.Web.Services

@{
    ViewData["Title"] = "Detalle del objetivo";
}

<div class="page-header mb-4">
    <div>
        <h1 class="page-title">Detalle del objetivo</h1>
        <p class="page-subtitle">
            Consultá el avance, los resultados clave y los seguimientos registrados.
        </p>
    </div>

    <a asp-page="./Index" class="btn btn-light btn-volver">
        ← Volver
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger rounded-4">
        @TempData["Error"]
    </div>
}

<div class="baykus-card employee-detail-card mb-4">
    <div class="employee-profile-header mb-4">
        <div class="employee-profile-main">
            <div class="employee-avatar" style="font-size: 2.4rem !important">
                🎯
            </div>

            <div>
                <div class="employee-profile-name">
                    @Model.Objetivo.Titulo
                </div>

                <div class="employee-profile-subtitle">
                    @(Model.Objetivo.Sector?.Nombre ?? "Sin sector")
                    ·
                    @(Model.Objetivo.Puesto?.Nombre ?? "Todos los puestos")
                </div>
            </div>
        </div>

        <div class="employee-profile-actions">
            <a asp-page="./Edit"
               asp-route-id="@Model.Objetivo.Id"
               class="btn btn-primary btn-form">
                Editar objetivo
            </a>
        </div>
    </div>

    <div class="detail-section">
        <div class="detail-list">

            <div class="detail-item">
                <div class="detail-label">Responsable</div>
                <div class="detail-value">
                    @if (Model.Objetivo.EmpleadoResponsable != null)
                    {
                        @($"{Model.Objetivo.EmpleadoResponsable.Nombre} {Model.Objetivo.EmpleadoResponsable.Apellido}")
                    }
                    else
                    {
                        <span class="text-muted">Sin responsable</span>
                    }
                </div>
            </div>

            <div class="detail-item">
                <div class="detail-label">Período</div>
                <div class="detail-value">
                    @Model.Objetivo.FechaInicio.ToString("dd/MM/yyyy") -
                    @Model.Objetivo.FechaFin.ToString("dd/MM/yyyy")
                </div>
            </div>

            <div class="detail-item">
                <div class="detail-label">Estado</div>
                <div class="detail-value">
                    <span class="@OkrService.ObtenerClaseEstado(Model.Objetivo.Estado)">
                        @Model.Objetivo.Estado
                    </span>
                </div>
            </div>

            <div class="detail-item">
                <div class="detail-label">Avance general</div>
                <div class="detail-value">
                    <div class="d-flex justify-content-between small mb-1">
                        <span>@Model.Objetivo.Progreso%</span>
                    </div>

                    <div class="progress" style="height: 10px;">
                        <div class="progress-bar @OkrService.ObtenerClaseProgreso(Model.Objetivo.Progreso)"
                             style="width: @Model.Objetivo.Progreso%">
                        </div>
                    </div>
                </div>
            </div>

            <div class="detail-item">
                <div class="detail-label">Descripción</div>
                <div class="detail-value">
                    @if (!string.IsNullOrWhiteSpace(Model.Objetivo.Descripcion))
                    {
                        @Model.Objetivo.Descripcion
                    }
                    else
                    {
                        <span class="text-muted">Sin descripción</span>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<div class="baykus-card mb-4">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h2 class="form-section-title">Resultados clave</h2>
            <p class="form-section-subtitle">
                Son los indicadores que permiten medir si el objetivo se está cumpliendo.
            </p>
        </div>
    </div>

    <form method="post" asp-page-handler="AgregarResultado" asp-route-id="@Model.Objetivo.Id" class="row g-3 mb-4">
        <div class="col-md-10">
            <input asp-for="NuevoResultado.Descripcion"
                   class="form-control baykus-input"
                   placeholder="Ej: Reducir reclamos mensuales en un 20%" />
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">
                Agregar
            </button>
        </div>
    </form>

    @if (Model.Objetivo.ResultadosClave.Any())
    {
        <div class="table-responsive">
            <table class="table baykus-table align-middle">
                <thead>
                    <tr>
                        <th>Resultado clave</th>
                        <th style="width: 180px;">Avance</th>
                        <th style="width: 180px;">Actualizar</th>
                        <th>Estado</th>
                        <th class="text-end">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var resultado in Model.Objetivo.ResultadosClave.OrderBy(r => r.Id))
                    {
                        <tr>
                            <td>@resultado.Descripcion</td>

                            <td>
                                <div class="d-flex justify-content-between small mb-1">
                                    <span>@resultado.Progreso%</span>
                                </div>

                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar @OkrService.ObtenerClaseProgreso(resultado.Progreso)"
                                         style="width: @resultado.Progreso%">
                                    </div>
                                </div>
                            </td>

                            <td>
                                <form method="post"
                                      asp-page-handler="ActualizarResultado"
                                      asp-route-id="@Model.Objetivo.Id"
                                      asp-route-resultadoId="@resultado.Id"
                                      class="d-flex gap-2">
                                    <input type="number"
                                           name="progreso"
                                           class="form-control form-control-sm"
                                           min="0"
                                           max="100"
                                           value="@resultado.Progreso" />

                                    <button type="submit" class="btn btn-sm btn-outline-primary">
                                        OK
                                    </button>
                                </form>
                            </td>

                            <td>
                                <span class="@OkrService.ObtenerClaseEstado(resultado.Estado)">
                                    @resultado.Estado
                                </span>
                            </td>

                            <td class="text-end">
                                <form method="post"
                                      asp-page-handler="EliminarResultado"
                                      asp-route-id="@Model.Objetivo.Id"
                                      asp-route-resultadoId="@resultado.Id">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state py-4">
            <div class="empty-icon">📌</div>
            <h3>Sin resultados clave</h3>
            <p>
                Agregá al menos un resultado clave para empezar a medir el avance del objetivo.
            </p>
        </div>
    }
</div>

<div class="baykus-card">
    <h2 class="form-section-title">Seguimiento</h2>
    <p class="form-section-subtitle">
        Registrá comentarios, novedades o aclaraciones sobre el avance del objetivo.
    </p>

    <form method="post" asp-page-handler="AgregarSeguimiento" asp-route-id="@Model.Objetivo.Id" class="mb-4">
        <textarea asp-for="NuevoSeguimiento.Comentario"
                  class="form-control baykus-input mb-3"
                  rows="3"
                  placeholder="Ej: Se avanzó con la primera etapa, queda pendiente validar con el equipo."></textarea>

        <button type="submit" class="btn btn-primary">
            Agregar seguimiento
        </button>
    </form>

    @if (Model.Objetivo.Seguimientos.Any())
    {
        <div class="okr-timeline">
            @foreach (var seguimiento in Model.Objetivo.Seguimientos.OrderByDescending(s => s.Fecha))
            {
                <div class="okr-timeline-item">
                    <div class="okr-timeline-date">
                        @seguimiento.Fecha.ToString("dd/MM/yyyy HH:mm")
                    </div>

                    <div class="okr-timeline-text">
                        @seguimiento.Comentario
                    </div>

                    <div class="text-muted small">
                        @(seguimiento.Usuario ?? "Usuario")
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted mb-0">Todavía no hay seguimientos cargados.</p>
    }

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }